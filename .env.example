UV_PROJECT_ENVIRONMENT="${HOME}/.venvs/n225-open-gap-tail"
# This is a uv non-package project. The justfile runs the CLI with PYTHONPATH=src
# instead of relying on an installed console script.

PROJECT_NAME="n225-open-gap-tail"
PROJECT_TIMEZONE_JP="Asia/Tokyo"
PROJECT_TIMEZONE_US="America/New_York"
LOG_LEVEL="INFO"

DATA_DIR="data"
BRONZE_DATA_DIR="data/bronze"
SILVER_DATA_DIR="data/silver"
GOLD_DATA_DIR="data/gold"
REPORTS_DIR="reports"

# Runtime vendor authentication uses key files only; do not put raw API keys in `.env`.
MASSIVE_API_KEY_FILE="/path/to/massive.keyfile"
MASSIVE_FLAT_FILE_KEY_FILE="/path/to/massive-flat-file.keyfile"
MASSIVE_BASE_URL="https://api.massive.com"
MASSIVE_REQUEST_TIMEOUT_SECONDS="30"
MASSIVE_MIN_REQUEST_INTERVAL_SECONDS="0"
MASSIVE_MAX_RETRIES="2"
MASSIVE_RATE_LIMIT_BACKOFF_SECONDS="60"
MASSIVE_DAILY_TICKERS="SPY,QQQ,DIA,IWM,XLK,XLF,XLE,XLV,XLI,XLY,XLP,XLB,XLU,XLC,TLT,GLD,USO,EEM,FXI,SMH,HYG,LQD,EWJ,DXJ,EWY,EWT,EWH"
MASSIVE_MINUTE_TICKER="SPY"
MASSIVE_PROBE_TICKERS="I:VIX"
MASSIVE_REGULAR_SESSION_START_ET="09:30"
MASSIVE_REGULAR_SESSION_END_ET="16:00"

FRED_BASE_URL="https://fred.stlouisfed.org"
FRED_REQUEST_TIMEOUT_SECONDS="30"
FRED_SERIES="VIXCLS,DGS2,DGS10,T10Y2Y,DEXJPUS,BAMLH0A0HYM2,BAMLC0A0CM"

CBOE_BASE_URL="https://cdn.cboe.com"
CBOE_VOL_INDEX_SYMBOLS="VIX"
CBOE_REQUEST_TIMEOUT_SECONDS="30"

CALENDAR_US_EXCHANGE="XNYS"
CALENDAR_JPX_EXCHANGE="JPX"

NIKKEI_CONTRACT_ROLL_DAYS_BEFORE_LAST_TRADE="5"
NIKKEI_CONTRACT_MONTHS="3,6,9,12"

# J-Quants API V2 is selected by the base URL. Premium futures access is required.
JQUANTS_API_KEY_FILE="/path/to/jquants.keyfile"
JQUANTS_API_BASE_URL="https://api.jquants.com/v2"
JQUANTS_EQUITY_MASTER_ENABLED="true"
JQUANTS_EQUITY_DAILY_ENABLED="true"
JQUANTS_DERIVATIVES_DAILY_ENABLED="true"
JQUANTS_DERIVATIVES_INTRADAY_ENABLED="false"
JQUANTS_REQUEST_TIMEOUT_SECONDS="30"

JPX_DATACUBE_EMAIL="replace-me"
JPX_DATACUBE_PASSWORD="replace-me"
JPX_DATACUBE_BASE_URL="https://dc.jpx-jquants.com"
